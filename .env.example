# ──────────────────────────────────────────────────────────────────────────────
# ForexMind AI Trading Agent — Environment Configuration Template
# Copy this file to .env and fill in your API keys.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── OANDA (Primary Forex Data + Paper Trading) ───────────────────────────────
# 1. Sign up free at: https://www.oanda.com/register/#/
#    Choose "Practice" account — $100,000 virtual money, no credit card needed.
# 2. Log in → My Account → Manage API Access → Generate Token
OANDA_API_KEY=your_oanda_api_key_here
OANDA_ACCOUNT_ID=your_oanda_account_id_here
# "practice" for paper trading (safe default), "live" for real money
OANDA_ENVIRONMENT=practice

# ── Anthropic Claude (AI Conversational Brain) ───────────────────────────────
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Recommended: claude-3-5-sonnet-20241022 (fast + smart) or claude-opus-4-5 (best reasoning)
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# ── Alpha Vantage (News + Historical OHLCV Backup) ───────────────────────────
# Free key (no credit card): https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# ── Finnhub (Real-time News & Forex Data) ────────────────────────────────────
# Free tier: https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_key_here

# ── Telegram Bot (Optional — Signal Alerts & Chat) ───────────────────────────
# 1. Open Telegram, search for @BotFather
# 2. Send /newbot, follow prompts, copy the token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Your personal Telegram user ID — message @userinfobot to get it
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── Application Settings ─────────────────────────────────────────────────────
LOG_LEVEL=INFO
# Port for the FastAPI web dashboard
WEB_PORT=8000
# Set to False ONLY when you are ready for real money trading
PAPER_TRADING=True
# SQLite database path (relative to project root)
DATABASE_URL=sqlite+aiosqlite:///./data/forexmind.db
